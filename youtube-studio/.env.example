# ═══════════════════════════════════════════════════
# YouTube Studio — 环境变量配置
# 复制此文件为 .env 后填入实际值
# ═══════════════════════════════════════════════════

# ── 频道信息 ──
CHANNEL_NAME=My YouTube Channel

# ── n8n 工作流 ──
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
N8N_WEBHOOK_URL=

# ── YouTube API (OAuth) ──
# 需要 Google Cloud Console 启用 YouTube Data API v3
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ── Claude API（脚本生成）──
CLAUDE_API_KEY=

# ── AI 生图（缩略图，默认 flux-dev）──
THUMBNAIL_MODEL=flux-dev

# ── MuAPI（Shorts Generator API 模式，https://muapi.ai）──
MUAPI_API_KEY=
MUAPI_BASE_URL=https://api.muapi.ai/api/v1

# ── 本地模式配置（Shorts Generator Local 模式）──
LLM_PROVIDER=openai           # openai 或 gemini
OPENAI_API_KEY=
GEMINI_API_KEY=
LOCAL_WHISPER_MODEL=base
